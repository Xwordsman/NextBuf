NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# App
PORT=3000
DEPLOYMENT_VERSION=local
# Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Database
POSTGRES_DB=nextbuf
POSTGRES_USER=nextbuf
POSTGRES_PASSWORD=nextbuf-change-me
DATABASE_URL=postgres://nextbuf:nextbuf-change-me@postgres:5432/nextbuf
DATABASE_MAX_CONNECTIONS=10

# Redis is reserved for cache/rate-limit/session enhancements.
REDIS_URL=redis://redis:6379

# Docker image used by docker-compose.yml on servers.
NEXTBUF_IMAGE=ghcr.io/xwordsman/nextbuf:latest
